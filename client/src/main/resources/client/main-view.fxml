<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane prefHeight="386.0" prefWidth="448.0" styleClass="mainStackPane" stylesheets="@styles/base.css"
           xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="client.view.MainController">
    <children>
        <AnchorPane prefHeight="200.0" prefWidth="200.0">
            <children>
                <BorderPane fx:id="borderPane" prefHeight="260.0" prefWidth="291.0" AnchorPane.bottomAnchor="0"
                            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <children>
                                <ToolBar prefHeight="40.0" prefWidth="200.0">
                                    <items>
                                        <Button mnemonicParsing="false" onAction="#handleNewEmailClick"
                                                text="Написать"/>
                                        <Button mnemonicParsing="false" fx:id="deleteButton"  onAction="#handleDeleteClick" text="Удалить"/>
                                        <Button mnemonicParsing="false" onAction="#handleLogoutClick"
                                                text="Выйти из аккаунта"/>
                                    </items>
                                </ToolBar>
                            </children>
                        </VBox>
                    </top>
                    <center>
                        <SplitPane fx:id="splitPane" dividerPositions="0.23842592592592593, 0.5162037037037037"
                                   BorderPane.alignment="TOP_LEFT">
                            <items>
                                <VBox maxWidth="1.7976931348623157E308" minWidth="100.0">
                                    <TreeView fx:id="tree" prefHeight="200.0" prefWidth="200.0" showRoot="false"
                                              VBox.vgrow="ALWAYS">
                                        <TreeItem value="root">
                                            <!--                                            <children>-->
                                            <!--                                                <TreeItem value="Папки" expanded="true">-->
                                            <!--                                                &lt;!&ndash;                                                    <children>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                        <TreeItem value="Вся почта"/>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                        <TreeItem value="Входящие"/>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                        <TreeItem value="Исходящие"/>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                        <TreeItem value="Черновики"/>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                        <TreeItem value="Папки"/>&ndash;&gt;-->
                                            <!--                                                &lt;!&ndash;                                                    </children>&ndash;&gt;-->
                                            <!--                                                </TreeItem>-->
                                            <!--                                                <TreeItem value="Теги">-->

                                            <!--                                                </TreeItem>-->
                                            <!--                                            </children>-->
                                        </TreeItem>
                                    </TreeView>
                                </VBox>
                                <VBox maxWidth="1.7976931348623157E308" minWidth="100.0">
                                    <children>
                                        <HBox>
                                            <children>
                                                <Button fx:id="refreshButton" alignment="CENTER" mnemonicParsing="false"
                                                        onAction="#handleClick" textAlignment="CENTER"
                                                        HBox.hgrow="NEVER">
                                                    <graphic>
                                                        <FontIcon iconLiteral="fth-refresh-cw" iconSize="16"/>
                                                    </graphic>
                                                </Button>
<!--                                                <Button fx:id="sortButton" alignment="CENTER" mnemonicParsing="false"-->
<!--                                                        onAction="#handleSort" text="Порядок" textAlignment="CENTER"-->
<!--                                                        HBox.hgrow="NEVER">-->
<!--                                                    <graphic>-->
<!--                                                        <FontIcon iconLiteral="fth-list" iconSize="16"/>-->
<!--                                                    </graphic>-->
<!--                                                </Button>-->
                                                <ChoiceBox fx:id="sortChoice" prefWidth="150.0">
                                                </ChoiceBox>
                                            </children>
                                        </HBox>
                                        <ListView fx:id="emailsList" VBox.vgrow="ALWAYS"/>
                                    </children>
                                </VBox>
                                <Label fx:id="userLabel" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308"
                                       maxWidth="1.7976931348623157E308" minWidth="100.0" text="Label"/>
                            </items>
                        </SplitPane>
                    </center>
                </BorderPane>
            </children>
        </AnchorPane>
    </children>
</StackPane>
