<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="275.0" prefWidth="414.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" 
   fx:controller="client.view.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <BorderPane prefHeight="262.0" prefWidth="374.0">
      <top>
         <MenuBar BorderPane.alignment="CENTER">
           <menus>
             <Menu mnemonicParsing="false" text="File">
               <items>
                 <MenuItem mnemonicParsing="false" text="Close" />
               </items>
             </Menu>
             <Menu mnemonicParsing="false" text="Edit">
               <items>
                 <MenuItem mnemonicParsing="false" text="Delete" />
               </items>
             </Menu>
             <Menu mnemonicParsing="false" text="Help">
               <items>
                 <MenuItem mnemonicParsing="false" text="About" />
               </items>
             </Menu>
           </menus>
         </MenuBar>
      </top>
      <left>
         <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>
               <HBox prefHeight="100.0" prefWidth="200.0">
                  <children>
                     <Button alignment="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="71.0" text="Refresh" textAlignment="CENTER"
                        onAction="#handleClick"/>
                  </children>
               </HBox>
               <ListView fx:id="emailsList" />
            </children>
         </VBox>
      </left>
      <center>
         <Label fx:id="userLabel" text="Label" BorderPane.alignment="CENTER" />
      </center>
   </BorderPane>
</VBox>
