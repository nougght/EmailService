<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<AnchorPane prefHeight="468.0" styleClass="anchor-pane-compose" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.view.EmailFormController">
    <children>
        <VBox alignment="CENTER" styleClass="composeVBox" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                              <HBox alignment="CENTER">
                                  <children>
                                      <Label alignment="BOTTOM_LEFT" contentDisplay="CENTER" text="Кому:">
                                          <HBox.margin>
                                              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                          </HBox.margin>
                                      </Label>
                                      <TextField fx:id="receiverField" alignment="BOTTOM_LEFT" HBox.hgrow="ALWAYS">
                                          <HBox.margin>
                                              <Insets bottom="10.0" right="10.0" top="10.0" />
                                          </HBox.margin>
                                      </TextField>
                                      <Button mnemonicParsing="false" onAction="#handleAddRecipients"
                                              styleClass="compose-add-recipient">
                                          <graphic>
                                              <FontIcon iconLiteral="fth-user-plus" iconSize="18"/>
                                          </graphic>
                                          <HBox.margin>
                                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                          </HBox.margin>
                                      </Button>
                                  </children>
                              </HBox>
                            <HBox alignment="CENTER">
                                <children>
                                    <TextField fx:id="subjectField" alignment="CENTER" promptText="Введите заголовок" HBox.hgrow="ALWAYS">
                                        <HBox.margin>
                                            <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                                        </HBox.margin>
                                    </TextField>
                                </children>
                            </HBox>
                     </children>
                  </VBox>
                        <ListView fx:id="recipientsList" maxHeight="300.0" prefHeight="2.0" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <TextArea fx:id="bodyArea" prefHeight="200.0" prefWidth="200.0" promptText="Текст письма" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </TextArea>
                <Label fx:id="warningLabel" text="Label" />
                <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleSendClick"
                        styleClass="compose-send-button" text="Отправить">
                    <graphic>
                        <FontIcon iconLiteral="fth-send" iconSize="18"/>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </VBox.margin>
                </Button>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
