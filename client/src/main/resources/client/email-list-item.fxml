<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="root" fx:controller="client.view.EmailListItemController" spacing="6"
      styleClass="email-list-item">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <children>
                <Label minWidth="56.0" styleClass="email-list-item-field-label" text="Тема:"/>
                <Label fx:id="subjectLabel" maxWidth="Infinity" styleClass="email-list-item-subject" HBox.hgrow="ALWAYS"
                       wrapText="false"/>
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <children>
                <Label fx:id="counterpartyPrefixLabel" minWidth="56.0" styleClass="email-list-item-field-label"
                       text="От:"/>
                <Label fx:id="counterpartyLabel" maxWidth="Infinity" styleClass="email-list-item-counterparty"
                       HBox.hgrow="ALWAYS" wrapText="false"/>
            </children>
        </HBox>
        <HBox fx:id="snippetRow" alignment="TOP_LEFT" spacing="8">
            <children>
                <Label minWidth="56.0" styleClass="email-list-item-field-label" text="Текст:"/>
                <Label fx:id="snippetLabel" maxWidth="Infinity" styleClass="email-list-item-snippet" HBox.hgrow="ALWAYS"
                       wrapText="true"/>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
</VBox>
