<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="554.0" prefWidth="582.0" styleClass="registrationView" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.view.RegistrationController">
   <content>
      <StackPane prefHeight="439.0" prefWidth="441.0">
         <children>
            <AnchorPane>
               <children>
                  <VBox alignment="CENTER" maxHeight="275.0" maxWidth="300.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        
                        <Label fx:id="registrationLabel" styleClass="authTitle" text="Регистрация" />
                        <TextField fx:id="usernameInput" promptText="Имя пользователя" styleClass="usernameField" />
                        <PasswordField fx:id="passwordInput" promptText="Пароль" styleClass="passwordField" />
                     <PasswordField fx:id="passwordConfirmationInput" layoutX="30.0" layoutY="251.0" promptText="Подтверждение пароля" styleClass="passwordField" />
                        <Label fx:id="warningLabel" />
                        <Button fx:id="registrationButton" onAction="#handleRegistrationClick" text="Зарегистрироваться" textAlignment="CENTER" />
                     <AnchorPane>
                        <children>
                              <Button fx:id="toLoginButton" onAction="#handleToLoginClick" text="Уже есть аккаунт" textAlignment="CENTER" AnchorPane.rightAnchor="5.0" />
                        </children>
                     </AnchorPane>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  
                    </VBox>
               </children>
            </AnchorPane>
         </children>
      </StackPane>
   </content>
</ScrollPane>
